<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Black Beauty Brands — Your favorite products, in one place") }}</title>
  <meta name="description" content="{{ description | default("Find Black-owned beauty products at the best prices across retailers. Compare prices and shop with confidence.") }}">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ title | default('Black Beauty Brands') }}">
  <meta property="og:description" content="{{ description | default('Find Black-owned beauty products at the best prices across retailers.') }}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Black Beauty Brands">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
  {% include "nav.njk" %}
  <main class="site-main">
    {{ content | safe }}
  </main>
  {% include "footer.njk" %}
</body>
</html>
