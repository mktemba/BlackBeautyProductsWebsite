---
layout: base.njk
pagination:
  data: brands
  size: 1
  alias: brand
permalink: "/brands/{{ brand.slug }}/"
eleventyComputed:
  title: "{{ brand.name | safe }} - Black Beauty Brands"
  description: "{{ brand.bio | safe }}"
---

<div class="breadcrumbs">
  <a href="{{ '/' | url }}">Home</a>
  <span class="separator">&rsaquo;</span>
  <a href="{{ '/brands/' | url }}">Brands</a>
  <span class="separator">&rsaquo;</span>
  {{ brand.name }}
</div>

<div class="brand-header">
  <h1 class="brand-name">{{ brand.name }}</h1>
  <div class="brand-meta">
    Founded {{ brand.founded }}
    {% set brandProducts = products | filterByBrand(brand.slug) %}
    &middot; {{ brandProducts.length }} product{{ "s" if brandProducts.length != 1 }}
    {% if brand.website %}
    &middot; <a href="{{ brand.website }}" target="_blank" rel="noopener">Visit website</a>
    {% endif %}
  </div>
  <p class="brand-bio">{{ brand.bio }}</p>
</div>

<div class="product-grid">
  {% for product in brandProducts %}
    {% include "product-card.njk" %}
  {% endfor %}
</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}{{ '/' | url }}" },
    { "@type": "ListItem", "position": 2, "name": "Brands", "item": "{{ site.url }}{{ '/brands/' | url }}" },
    { "@type": "ListItem", "position": 3, "name": {{ brand.name | dump | safe }} }
  ]
}
</script>
