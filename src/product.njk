---
layout: base.njk
pagination:
  data: products
  size: 1
  alias: product
permalink: "/products/{{ product.slug }}/"
eleventyComputed:
  title: "{{ product.name | safe }} - Compare Prices | Black Beauty Brands"
  description: "{{ product.description | safe }} Compare prices across retailers and find the best deal."
  ogType: "product"
  ogImage: "{{ product.image }}"
---

{% set brand = brands | findBrand(product.brand) %}
{% set category = categories | findCategory(product.category) %}
{% set productPrices = prices[product.slug] %}

<div class="breadcrumbs">
  <a href="{{ '/' | url }}">Home</a>
  <span class="separator">&rsaquo;</span>
  {% if category %}
  <a href="{{ ('/' + category.slug + '/') | url }}">{{ category.name }}</a>
  <span class="separator">&rsaquo;</span>
  {% endif %}
  {{ product.name }}
</div>

<div class="product-detail">
  <div class="product-detail-image">
    {% if product.image %}
      <img src="{{ product.image }}" alt="{{ product.name }}">
    {% else %}
      <div class="product-detail-image-placeholder">No image available</div>
    {% endif %}
  </div>

  <div class="product-detail-info">
    <div class="product-detail-brand">
      {% if brand %}
        <a href="{{ ('/brands/' + brand.slug + '/') | url }}">{{ brand.name }}</a>
      {% endif %}
    </div>
    <h1 class="product-detail-name">{{ product.name }}</h1>
    <p class="product-detail-description">{{ product.description }}</p>

    {% include "price-table.njk" %}
  </div>
</div>

{% set sortedPrices = productPrices | sortByPrice %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.name | dump | safe }},
  "description": {{ product.description | dump | safe }},
  {% if product.image %}"image": {{ product.image | dump | safe }},{% endif %}
  {% if brand %}"brand": { "@type": "Brand", "name": {{ brand.name | dump | safe }} },{% endif %}
  {% if sortedPrices.length > 0 %}
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "USD",
    "lowPrice": {{ sortedPrices[0].price }},
    "highPrice": {{ sortedPrices[sortedPrices.length - 1].price }},
    "offerCount": {{ sortedPrices.length }}
  }
  {% endif %}
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}{{ '/' | url }}" }
    {% if category %},{ "@type": "ListItem", "position": 2, "name": {{ category.name | dump | safe }}, "item": "{{ site.url }}{{ ('/' + category.slug + '/') | url }}" }{% endif %}
    ,{ "@type": "ListItem", "position": {% if category %}3{% else %}2{% endif %}, "name": {{ product.name | dump | safe }} }
  ]
}
</script>
